{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txreceipts.com.tr/schema/intent.schema.json",
  "title": "TxReceipts Dapp Intent",
  "type": "object",
  "required": ["version", "chainId", "txHash", "intent"],
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "chainId": {
      "type": "integer",
      "const": 8453
    },
    "txHash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "user": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "merchant": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "url": { "type": "string", "format": "uri" },
        "reference": { "type": "string", "maxLength": 120 }
      },
      "additionalProperties": false
    },
    "intent": {
      "type": "object",
      "required": ["type", "summary"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["transfer", "swap", "mint", "payment", "subscription", "bridge", "approval", "unknown"]
        },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "sent": {
          "type": "array",
          "items": { "$ref": "#/$defs/assetAmount" }
        },
        "received": {
          "type": "array",
          "items": { "$ref": "#/$defs/assetAmount" }
        },
        "fees": {
          "type": "array",
          "items": { "$ref": "#/$defs/fee" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "assetAmount": {
      "type": "object",
      "required": ["symbol", "amount"],
      "properties": {
        "symbol": { "type": "string", "minLength": 1, "maxLength": 20 },
        "amount": { "type": "string" },
        "address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 36 }
      },
      "additionalProperties": false
    },
    "fee": {
      "type": "object",
      "required": ["type", "amount", "symbol"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["app", "protocol", "network", "merchant", "other"]
        },
        "amount": { "type": "string" },
        "symbol": { "type": "string" },
        "recipient": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        }
      },
      "additionalProperties": false
    }
  }
}
